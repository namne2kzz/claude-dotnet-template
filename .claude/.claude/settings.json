{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/scripts/post-write.ps1"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/scripts/pre-write.ps1"
          }
        ]
      }
    ]
  }
}
